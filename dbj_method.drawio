        <mxCell id="DBuvhJ8lUVWIasfX2SSk-6" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;DBJ METHOD&lt;/h1&gt;&lt;p&gt;(c) dbj@dbj.org&lt;br&gt;CC BY SA 4.0&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="-2180" y="1430" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="DBuvhJ8lUVWIasfX2SSk-7" value="Develop a Workflow describing the System&amp;nbsp;&lt;div&gt;Start with logical System Decomposition&lt;/div&gt;&lt;div&gt;DDD is not ,mandatory, espeicaly when&lt;/div&gt;&lt;div&gt;there is not &quot;Discovery&quot; pahse,&amp;nbsp;&lt;/div&gt;&lt;div&gt;That means Legacy systems&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="-2180" y="1110" width="460" height="220" as="geometry" />
        </mxCell>
        <mxCell id="DBuvhJ8lUVWIasfX2SSk-8" value="Modules map to Swimlanes from a workflow&lt;div&gt;Use Cases are Processes in that Swimlane&lt;br&gt;System is partitioned in functional&amp;nbsp; modules&lt;/div&gt;&lt;div&gt;Primary objective is reslience to change over time&lt;/div&gt;&lt;div&gt;Busines can change the requirements and will se the system as not difficult to change&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="-1503" y="1090" width="573" height="240" as="geometry" />
        </mxCell>
        <mxCell id="DBuvhJ8lUVWIasfX2SSk-9" value="Module is a logical unit, it can be mapped to a physical unit, e.g. container&lt;div&gt;Primary objective for a moduie is it is &quot;hot swappable&quot;&lt;br&gt;&lt;div&gt;Use case maps to a process&lt;/div&gt;&lt;div&gt;Communicatio is striclty&amp;nbsp; through Module API&lt;/div&gt;&lt;div&gt;One Modue logicaly has &quot;one data&quot;, physicaly it can be one schema in a common db evolving towards separate db&lt;br&gt;Modularised system does not mean micro-services&lt;/div&gt;&lt;/div&gt;&lt;div&gt;Production and Deployment and Hosting are best automatised&lt;br&gt;Standardisation rulesm that leads to simplification and that leads to risk mitigation&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="-870" y="1130" width="826" height="220" as="geometry" />
        </mxCell>
        <mxCell id="DBuvhJ8lUVWIasfX2SSk-10" value="&lt;h1 style=&quot;margin-top: 0px; font-size: 24px;&quot;&gt;Notes&lt;/h1&gt;&lt;div style=&quot;font-size: 24px;&quot;&gt;&lt;ul&gt;&lt;li&gt;common vocabulary is most important&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=24;" vertex="1" parent="1">
